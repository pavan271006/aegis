# ---- Core ----
APP_NAME=AEGIS Lite
DATABASE_URL=postgresql+psycopg2://aegis:aegis@db:5432/aegis
REDIS_URL=redis://redis:6379/0
API_KEY=replace-with-a-long-random-string

# ---- Autonomy ----
# dry-run = log only | approval = queue for your OK | auto = act automatically
RESPONSE_MODE=dry-run
BLOCK_TTL_HOURS=24
AUTO_BLOCK_MIN_SEVERITY=high

# ---- Cloudflare (optional, needed for live blocking) ----
CF_API_TOKEN=
CF_ZONE_ID=

# ---- CrowdSec (optional) ----
CROWDSEC_URL=
CROWDSEC_API_KEY=

# ---- Telegram alerts (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- GeoIP enrichment (free ip-api.com) ----
GEOIP_ENABLED=true

# ---- Detection thresholds ----
FAILED_AUTH_THRESHOLD=5
SCAN_404_THRESHOLD=15
RATE_Z_THRESHOLD=3.0

# ---- Scheduler ----
MONITORING_INTERVAL_MINUTES=5
DIGEST_CRON="0 9 * * 1"

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ---- Upload Quarantine ----
QUARANTINE_DIR="/tmp/aegis_quarantine"
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=".pdf,.doc,.docx,.xlsx,.csv,.txt,.png,.jpg,.jpeg,.gif"

# ---- Wazuh ----
WAZUH_URL=
WAZUH_USER=
WAZUH_PASSWORD=
